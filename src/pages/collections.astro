---
import Layout from "../layouts/Layout.astro";
import { collections, stones } from "../data/catalog";

const pageTitle = "Stone Collections | Alliance Granite & Quartz";
const pageDescription =
  "Explore curated collections of granite, quartz and marble surfaces designed for premium kitchens and interiors.";

const canonical = "https://www.alliancegranitequartz.com/collections";
---

<Layout title={pageTitle} description={pageDescription} canonical={canonical}>
  <main class="bg-[#0b0b0b] pt-28 text-white">
    <section class="relative overflow-hidden border-b border-white/10 bg-[#111111] py-24">
      <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 15% 20%, rgba(201,168,76,0.28), transparent 55%), radial-gradient(circle at 85% 10%, rgba(255,255,255,0.12), transparent 45%);"></div>
      <div class="relative mx-auto max-w-7xl px-6 text-center" data-reveal>
        <p class="mb-4 text-[10px] uppercase tracking-[0.35em] text-[#c9a84c]/80">Our Curated Range</p>
        <h1 class="mx-auto max-w-4xl font-serif text-4xl leading-tight md:text-6xl">
          Distinct Collections,
          <span class="text-[#c9a84c]"> Crafted for Lasting Interiors</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-sm leading-relaxed text-white/60 md:text-base">
          Each collection is assembled to balance visual identity, durability and installation performance.
          Browse the full selection and move into the stone catalog for details.
        </p>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-24">
      <div class="grid gap-8 lg:grid-cols-3">
        {collections.map((collection, i) => {
          const count = stones.filter((stone) => stone.collectionId === collection.id).length;
          return (
            <article
              class="group overflow-hidden border border-white/10 bg-[#121212]"
              data-reveal
              data-reveal-delay={String(i + 1)}
            >
              <div class="relative aspect-[4/3] overflow-hidden">
                <img
                  src={collection.image}
                  alt={collection.name}
                  class="h-full w-full object-cover grayscale transition duration-700 group-hover:scale-105 group-hover:grayscale-0"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/15 to-transparent"></div>
                <p class="absolute bottom-4 left-4 text-[10px] uppercase tracking-[0.3em] text-[#c9a84c]/90">
                  {count} Stones
                </p>
              </div>
              <div class="space-y-4 p-7">
                <h2 class="font-serif text-3xl">{collection.name}</h2>
                <p class="text-[11px] uppercase tracking-[0.25em] text-[#c9a84c]/70">{collection.tagline}</p>
                <p class="text-sm leading-relaxed text-white/60">{collection.description}</p>
                <a
                  href="/stones"
                  class="inline-flex items-center gap-3 border border-white/20 px-5 py-2 text-[10px] uppercase tracking-[0.28em] text-white/70 transition hover:border-[#c9a84c] hover:text-[#c9a84c]"
                >
                  View Stones
                  <span aria-hidden="true">-></span>
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <section class="border-y border-white/10 bg-[#0f0f0f] py-20">
      <div class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-8 px-6 md:flex-row md:items-center">
        <div data-reveal>
          <p class="mb-3 text-[10px] uppercase tracking-[0.35em] text-[#c9a84c]/80">Need guidance?</p>
          <h3 class="font-serif text-3xl md:text-4xl">Let us recommend the right material.</h3>
        </div>
        <a
          href="/#contact"
          class="border border-[#c9a84c] px-8 py-3 text-[10px] uppercase tracking-[0.3em] text-white transition hover:bg-[#c9a84c] hover:text-stone-900"
          data-reveal
          data-reveal-delay="2"
        >
          Book Consultation
        </a>
      </div>
    </section>
  </main>
</Layout>
