---
import Layout from "../../layouts/Layout.astro";
import { getFeaturedProjects, getProjectBySlug } from "../../data/portfolio";
import { stones } from "../../data/catalog";
import type { Project } from "../../data/portfolio";
import type { Stone } from "../../data/catalog";

export function getStaticPaths() {
  return getFeaturedProjects().map((project: Project) => ({
    params: { slug: project.slug }
  }));
}

const slug = Astro.params.slug as string;
const project = getProjectBySlug(slug) as Project | undefined;

if (!project) {
  return Astro.redirect("/portfolio");
}

const materialCards: Stone[] = stones.filter((stone: Stone) => project.materials.includes(stone.slug));
const relatedProjects: Project[] = getFeaturedProjects()
  .filter((item: Project) => item.slug !== project.slug)
  .slice(0, 3);

const pageTitle = `${project.title} | Portfolio | Alliance Granite & Quartz`;
const pageDescription = `${project.title} in ${project.location}. ${project.summary}`;
const canonical = `https://www.alliancegranitequartz.com/portfolio/${project.slug}`;
---

<Layout title={pageTitle} description={pageDescription} canonical={canonical}>
  <main class="bg-[#0b0b0b] pt-28 text-white">
    <section class="mx-auto grid max-w-7xl gap-10 px-6 pb-20 md:grid-cols-2 md:pt-10">
      <div class="overflow-hidden border border-white/10 bg-[#101010]" data-reveal>
        <img src={project.heroImage} alt={project.title} class="h-full w-full object-cover" />
      </div>

      <div class="space-y-7" data-reveal data-reveal-delay="2">
        <p class="text-[10px] uppercase tracking-[0.35em] text-[#c9a84c]/80">Portfolio Project</p>
        <h1 class="font-serif text-4xl leading-tight md:text-6xl">{project.title}</h1>
        <p class="text-sm uppercase tracking-[0.24em] text-white/45">{project.location} . Completed {project.completedAt}</p>
        <p class="max-w-xl text-base leading-relaxed text-white/65">{project.summary}</p>

        <div class="border border-white/10 bg-[#111111] p-6">
          <p class="mb-3 text-[10px] uppercase tracking-[0.3em] text-[#c9a84c]/80">Scope</p>
          <ul class="space-y-2 text-sm text-white/70">
            {project.scope.map((item: string) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="flex flex-wrap gap-4">
          <a
            href="/contact"
            class="border border-[#c9a84c] px-8 py-3 text-[10px] uppercase tracking-[0.3em] text-white transition hover:bg-[#c9a84c] hover:text-stone-900"
          >
            Start Your Project
          </a>
          <a
            href="/portfolio"
            class="border border-white/20 px-8 py-3 text-[10px] uppercase tracking-[0.3em] text-white/70 transition hover:border-[#c9a84c] hover:text-[#c9a84c]"
          >
            Back to Portfolio
          </a>
        </div>
      </div>
    </section>

    <section class="border-y border-white/10 bg-[#101010] py-16">
      <div class="mx-auto max-w-7xl px-6">
        <p class="mb-6 text-[10px] uppercase tracking-[0.35em] text-[#c9a84c]/80" data-reveal>Project Gallery</p>
        <div class="grid gap-4 md:grid-cols-3">
          {project.galleryImages.map((img: string, index: number) => (
            <div class="overflow-hidden border border-white/10 bg-[#111111]" data-reveal data-reveal-delay={String((index % 3) + 1)}>
              <img src={img} alt={`${project.title} gallery ${index + 1}`} class="aspect-square w-full object-cover" loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-20">
      <div class="mb-8" data-reveal>
        <p class="mb-2 text-[10px] uppercase tracking-[0.35em] text-[#c9a84c]/80">Materials Used</p>
        <h2 class="font-serif text-3xl md:text-4xl">Selected Stones</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {materialCards.map((stone: Stone, index: number) => (
          <a href={`/stones/${stone.slug}`} class="group overflow-hidden border border-white/10 bg-[#121212]" data-reveal data-reveal-delay={String(index + 1)}>
            <div class="aspect-[4/3] overflow-hidden">
              <img src={stone.image} alt={stone.name} class="h-full w-full object-cover transition duration-700 group-hover:scale-105" loading="lazy" />
            </div>
            <div class="space-y-2 p-5">
              <p class="text-[10px] uppercase tracking-[0.3em] text-[#c9a84c]/80">{stone.origin}</p>
              <h3 class="font-serif text-2xl">{stone.name}</h3>
              <p class="text-sm text-white/55">{stone.type} . {stone.tone}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="border-t border-white/10 bg-[#101010] py-20">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-10" data-reveal>
          <p class="mb-2 text-[10px] uppercase tracking-[0.35em] text-[#c9a84c]/80">More Work</p>
          <h2 class="font-serif text-3xl md:text-4xl">Related Projects</h2>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
          {relatedProjects.map((item: Project, index: number) => (
            <a href={`/portfolio/${item.slug}`} class="group overflow-hidden border border-white/10 bg-[#121212]" data-reveal data-reveal-delay={String(index + 1)}>
              <div class="aspect-video overflow-hidden">
                <img src={item.heroImage} alt={item.title} class="h-full w-full object-cover transition duration-700 group-hover:scale-105" loading="lazy" />
              </div>
              <div class="space-y-2 p-5">
                <p class="text-[10px] uppercase tracking-[0.3em] text-white/40">{item.location}</p>
                <h3 class="font-serif text-xl">{item.title}</h3>
                <p class="text-[10px] uppercase tracking-[0.24em] text-white/45">{item.completedAt}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
