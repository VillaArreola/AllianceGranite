---
import Layout from "../layouts/Layout.astro";
import { serviceAreas, serviceItems, serviceSteps } from "../data/services";

const pageTitle = "Services | Alliance Granite & Quartz";
const pageDescription =
  "Consultation, templating, fabrication, and installation services for kitchens, islands, vanities, backsplashes, countertops, and breakfast bars across the greater Philadelphia area.";
const canonical = "https://www.alliancegranitequartz.com/services";
---

<Layout title={pageTitle} description={pageDescription} canonical={canonical}>
  <main class="bg-[#0b0b0b] pt-28 text-white">
    <section class="relative overflow-hidden border-b border-white/10 bg-[#111111] py-24">
      <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 18% 20%, rgba(201,168,76,0.26), transparent 52%), radial-gradient(circle at 84% 16%, rgba(255,255,255,0.12), transparent 45%);"></div>
      <div class="relative mx-auto max-w-7xl px-6 text-center" data-reveal>
        <p class="mb-4 text-[10px] uppercase tracking-[0.35em] text-[#c9a84c]/80">Services</p>
        <h1 class="mx-auto max-w-4xl font-serif text-4xl leading-tight md:text-6xl">
          Practical Guidance,
          <span class="text-[#c9a84c]"> Precise Execution</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-sm leading-relaxed text-white/60 md:text-base">
          We keep the process simple: clear recommendations, accurate fabrication, and clean installation with responsive local communication.
        </p>
        <a
          href="/contact"
          class="mt-8 inline-block border border-[#c9a84c] px-10 py-3 text-[10px] uppercase tracking-[0.3em] text-white transition hover:bg-[#c9a84c] hover:text-stone-900"
        >
          Request Quote
        </a>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-24">
      <div class="mb-12" data-reveal>
        <h2 class="font-serif text-3xl md:text-5xl">What We Handle</h2>
        <p class="mt-3 max-w-2xl text-sm text-white/55">
          End-to-end support for kitchen, bath, and custom surface projects.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {serviceItems.map((service, index) => (
          <article class="border border-white/10 bg-[#121212] p-8" data-reveal data-reveal-delay={String((index % 4) + 1)}>
            <p class="mb-3 text-[10px] uppercase tracking-[0.3em] text-[#c9a84c]/80">{service.id.replace("-", " ")}</p>
            <h3 class="mb-3 font-serif text-3xl">{service.title}</h3>
            <p class="mb-4 text-sm leading-relaxed text-white/60">{service.short}</p>
            <p class="text-sm leading-relaxed text-white/50">{service.details}</p>
          </article>
        ))}
      </div>

      <div class="mt-16" data-reveal>
        <h3 class="font-serif text-2xl md:text-4xl">Popular Service Areas</h3>
        <p class="mt-3 max-w-3xl text-sm leading-relaxed text-white/55">
          We regularly complete projects for kitchens, kitchen islands, vanities, backsplashes, countertops, and breakfast bars.
        </p>
      </div>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {serviceAreas.map((area, index) => (
          <article
            class="group relative overflow-hidden border border-white/10 bg-[#101010] p-6 transition duration-500 ease-out hover:-translate-y-1 hover:border-[#c9a84c]/55"
            data-reveal
            data-reveal-delay={String((index % 4) + 1)}
          >
            <div class="pointer-events-none absolute inset-y-0 right-0 w-[58%] overflow-hidden opacity-35 transition duration-500 ease-out group-hover:opacity-45">
              <img
                src={area.image}
                alt={area.alt}
                loading="lazy"
                class="h-[120%] w-full translate-x-4 object-contain object-right transition duration-500 ease-out group-hover:scale-105 sm:translate-x-5"
              />
            </div>

            <p class="mb-2 text-[10px] uppercase tracking-[0.3em] text-[#c9a84c]/70">{area.id.replace("-", " ")}</p>
            <h4 class="font-serif text-2xl">{area.title}</h4>
            <p class="relative z-10 mt-3 max-w-[68%] text-sm leading-relaxed text-white/50 transition duration-500 group-hover:text-white/70 sm:max-w-[62%]">
              {area.description}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="border-y border-white/10 bg-[#101010] py-20">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-12 text-center" data-reveal>
          <h2 class="font-serif text-3xl md:text-5xl">How It Works</h2>
          <p class="mt-3 text-[10px] uppercase tracking-[0.35em] text-white/40">Simple 3-step flow</p>
        </div>

        <div class="grid gap-10 md:grid-cols-3">
          {serviceSteps.map((item, index) => (
            <div class="border-l border-[#c9a84c]/40 pl-6" data-reveal data-reveal-delay={String(index + 1)}>
              <span class="mb-3 block font-serif text-4xl text-[#c9a84c]/45">{item.step}</span>
              <h3 class="mb-3 font-serif text-2xl">{item.title}</h3>
              <p class="text-sm leading-relaxed text-white/55">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-20 text-center">
      <p class="mb-3 text-[10px] uppercase tracking-[0.35em] text-[#c9a84c]/80" data-reveal>Ready When You Are</p>
      <h2 class="font-serif text-3xl md:text-5xl" data-reveal data-reveal-delay="1">Tell us about your project.</h2>
      <p class="mx-auto mt-4 max-w-2xl text-sm leading-relaxed text-white/60" data-reveal data-reveal-delay="2">
        We will guide you to the right material and timeline for your space.
      </p>
      <a
        href="/contact"
        class="mt-8 inline-block border border-[#c9a84c] px-10 py-3 text-[10px] uppercase tracking-[0.3em] text-white transition hover:bg-[#c9a84c] hover:text-stone-900"
        data-reveal
        data-reveal-delay="3"
      >
        Request Quote
      </a>
    </section>
  </main>
</Layout>
