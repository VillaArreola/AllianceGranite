---
import { siteConfig } from "../../data/site";
---

<section
  id="contact"
  class="relative overflow-hidden bg-cover bg-center py-24"
  style="background-image: url('/images/gallery-4.jpg');">
  <!-- Light overlay to keep marble texture visible -->
  <div class="absolute inset-0 bg-white/60"></div>

  <div class="relative mx-auto grid max-w-5xl gap-12 px-6 md:grid-cols-2 md:items-center">
    <!-- Left: text info -->
    <div>
      <h2 class="text-4xl font-bold text-stone-900">Our Location</h2>
      <p class="mt-4 max-w-xs text-sm leading-relaxed text-stone-600">
        Visit us to explore our exquisite range of marble and granite products for kitchens and
        countertops in neutral colors and whites.
      </p>

      <div class="mt-8 space-y-4">
        <div>
          <p class="text-sm font-bold text-stone-900">Address</p>
          <p class="text-sm text-stone-700">{siteConfig.contact.address}</p>
        </div>
        <div>
          <p class="text-sm font-bold text-stone-900">Hours</p>
          <p class="text-sm text-stone-700">{siteConfig.contact.hours}</p>
        </div>
      </div>
    </div>

    <!-- Right: Google Maps embed -->
    <div class="overflow-hidden rounded-lg shadow-lg">
      <iframe
        title="Alliance Granite & Quartz location"
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3045.123456789!2d-75.4444!3d40.3939!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c6b0e0e0e0e0e0%3A0x1234567890abcdef!2s1862%20Tollgate%20Rd%2C%20Palm%2C%20PA%2018070!5e0!3m2!1sen!2sus!4v1700000000000"
        width="100%"
        height="350"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </div>
</section>
