---
const images = [
  { src: "/images/gallery-5.jpg", alt: "Granite countertop detail" },
  { src: "/images/gallery-6.jpg", alt: "Marble slab installation" },
];

const services = [
  {
    n: "01",
    title: "Consultation",
    desc: "Expert advice on material selection and design integration for your kitchen or bathroom.",
  },
  {
    n: "02",
    title: "Fabrication",
    desc: "State-of-the-art precision cutting and hand-finishing of every slab we supply.",
  },
  {
    n: "03",
    title: "Installation",
    desc: "Seamless integration by our experienced team — from templating to final polish.",
  },
];
---

<!-- Collections -->
<section id="about" class="bg-[#0d0d0d] pb-32 pt-16 md:pb-32 md:pt-20 text-white">
  <div class="mx-auto max-w-7xl px-6">
    <div class="flex flex-col items-center gap-20 md:flex-row">

      <!-- Left: text -->
      <div class="md:w-1/2" data-reveal>
        <p class="mb-4 text-[10px] uppercase tracking-[0.4em] text-[#c9a84c]/60">Who We Are</p>
        <h2 class="mb-8 font-serif text-4xl leading-tight md:text-6xl">
          Our Exclusive<br />
          <span class="italic text-[#c9a84c]/90">Collections</span>
        </h2>
        <p class="mb-10 max-w-md text-sm leading-relaxed text-white/50">
          At Alliance Granite &amp; Quartz, we specialize in providing high-quality granite, quartz
          and marble surfaces. Our offerings include stunning countertops and timeless kitchen
          designs in neutral colors that enhance any space. Every slab is hand-selected for beauty
          and durability.
        </p>
        <a
          href="/collections"
          class="border border-white/20 px-8 py-3 text-[10px] uppercase tracking-[0.3em] text-white transition hover:border-[#c9a84c] hover:text-[#c9a84c]"
        >
          View Full Catalog
        </a>
      </div>

      <!-- Right: stylized slab cards -->
      <div class="grid grid-cols-2 gap-5 md:w-1/2 md:gap-7" data-reveal data-reveal-delay="3">
        <article class="group relative aspect-[3/4] overflow-hidden rounded-[2px] border border-white/10 bg-[#171717] shadow-[0_20px_45px_rgba(0,0,0,0.5)] transition-transform duration-500 transform-gpu [transform:perspective(1200px)_rotateY(-3.5deg)] hover:[transform:perspective(1200px)_rotateY(-2deg)_translateY(-4px)_rotate(-0.5deg)]">
          <div class="pointer-events-none absolute inset-0 z-10 bg-gradient-to-br from-white/12 via-transparent to-transparent opacity-70"></div>
          <div class="pointer-events-none absolute -right-10 top-8 z-10 h-20 w-20 rounded-full bg-[#c9a84c]/20 blur-2xl transition-opacity duration-500 group-hover:opacity-90"></div>
          <img
            src={images[0].src}
            alt={images[0].alt}
            class="h-full w-full scale-[1.03] object-cover saturate-75 brightness-90 contrast-110 transition duration-700 group-hover:scale-[1.08] group-hover:saturate-100 group-hover:brightness-100"
            loading="lazy"
          />
          <div class="pointer-events-none absolute inset-x-0 bottom-0 z-10 h-20 bg-gradient-to-t from-black/45 to-transparent"></div>
        </article>

        <article class="group relative mt-10 aspect-[3/4] overflow-hidden rounded-[2px] border border-white/10 bg-[#171717] shadow-[0_24px_52px_rgba(0,0,0,0.58)] transition-transform duration-500 transform-gpu [transform:perspective(1200px)_rotateY(3.5deg)] hover:[transform:perspective(1200px)_rotateY(2deg)_translateY(-4px)_rotate(0.5deg)] md:mt-14">
          <div class="pointer-events-none absolute inset-0 z-10 bg-gradient-to-tr from-white/10 via-transparent to-transparent opacity-60"></div>
          <div class="pointer-events-none absolute -left-10 bottom-8 z-10 h-20 w-20 rounded-full bg-[#c9a84c]/20 blur-2xl transition-opacity duration-500 group-hover:opacity-90"></div>
          <img
            src={images[1].src}
            alt={images[1].alt}
            class="h-full w-full scale-[1.03] object-cover saturate-75 brightness-90 contrast-110 transition duration-700 group-hover:scale-[1.08] group-hover:saturate-100 group-hover:brightness-100"
            loading="lazy"
          />
          <div class="pointer-events-none absolute inset-x-0 bottom-0 z-10 h-20 bg-gradient-to-t from-black/45 to-transparent"></div>
        </article>
      </div>

    </div>
  </div>
</section>

<!-- Bespoke Services -->
<section id="services-full" class="bg-[#111111] py-32 text-white">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-20 text-center" data-reveal>
      <h2 class="mb-4 font-serif text-3xl md:text-5xl">Bespoke Services</h2>
      <p class="text-[10px] uppercase tracking-[0.4em] text-white/40">
        Crafting your vision into reality
      </p>
    </div>

    <div class="grid grid-cols-1 gap-16 md:grid-cols-3">
      {services.map((s, i) => (
        <div class="border-l border-[#c9a84c]/30 pl-8" data-reveal data-reveal-delay={String(i + 1)}>
          <span class="mb-4 block font-serif text-4xl text-[#c9a84c]/40">{s.n}</span>
          <h3 class="mb-4 font-serif text-xl text-white">{s.title}</h3>
          <p class="text-sm leading-relaxed text-white/50">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
