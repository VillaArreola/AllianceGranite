---
import { siteConfig } from "../../data/site";

const features = [
  {
    title: "Premium Quality",
    desc: "Hand selected stone slabs from around the world",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
    </svg>`,
  },
  {
    title: "Global Sourcing",
    desc: "Unrivaled access to rare and exclusive materials",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253" />
    </svg>`,
  },
  {
    title: "Expert Craftsmanship",
    desc: "Precision fabrication and seamless installation",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
    </svg>`,
  },
  {
    title: "Exceptional Service",
    desc: "Personalized dedication from start to finish",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 1 0 0 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186 9.566-5.314m-9.566 7.5 9.566 5.314m0 0a2.25 2.25 0 1 0 3.935 2.186 2.25 2.25 0 0 0-3.935-2.186Zm0-12.814a2.25 2.25 0 1 0 3.933-2.185 2.25 2.25 0 0 0-3.933 2.185Z" />
    </svg>`,
  },
];

const stones = [
  { name: "Calacatta Gold Marble", img: "/images/gallery-1.jpg" },
  { name: "Black Galaxy Granite",  img: "/images/gallery-2.jpg" },
  { name: "Carrara Quartz",        img: "/images/gallery-3.jpg" },
  { name: "Blue Bahia Granite",    img: "/images/gallery-4.jpg" },
];

const quickLinks = [
  { label: "Home",     href: "#hero" },
  { label: "About",    href: "#about" },
  { label: "Services", href: "#services" },
  { label: "Contact",  href: "#contact" },
];
---

<main
  id="floating-overview"
  class="relative z-20 mx-auto max-w-[1100px] -mt-48 mb-20 px-4 md:px-0 will-change-transform"
  style="transition: transform 0.1s linear;"
>
  <div class="border border-white/5 bg-[#111111] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.7)]">

    <!-- Why Choose Us -->
    <section class="border-b border-white/5 px-6 py-10 md:px-10">
      <div class="mb-8 text-center">
        <h2 class="mb-2 font-serif text-xl tracking-widest text-[#c9a84c]/80 md:text-2xl">
          Why Choose Us
        </h2>
        <div class="mx-auto h-px w-12 bg-[#c9a84c]/40"></div>
      </div>

      <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
        {features.map((f) => (
          <div class="px-2 text-center">
            <div class="mb-3 flex justify-center scale-75 text-[#c9a84c]" set:html={f.icon} />
            <h3 class="mb-1 font-serif text-[11px] uppercase tracking-[0.2em] text-white/90">
              {f.title}
            </h3>
            <p class="text-[9px] uppercase leading-relaxed tracking-widest text-white/30">
              {f.desc}
            </p>
          </div>
        ))}
      </div>
    </section>

    <!-- Featured Stones -->
    <section id="services" class="border-b border-white/5 px-6 py-10 md:px-10">
      <div class="mb-8 text-center">
        <h2 class="mb-2 font-serif text-xl tracking-widest text-[#c9a84c]/80 md:text-2xl">
          Featured Stones
        </h2>
        <div class="mx-auto h-px w-12 bg-[#c9a84c]/40"></div>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {stones.map((stone) => (
          <div class="group">
            <div class="mb-4 aspect-square overflow-hidden border border-white/5">
              <img
                src={stone.img}
                alt={stone.name}
                class="h-full w-full object-cover transition-transform duration-1000 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="text-center">
              <h3 class="mb-3 font-serif text-[11px] tracking-wider text-white/70">
                {stone.name}
              </h3>
              <a
                href="#contact"
                class="border border-white/10 px-4 py-1.5 text-[8px] uppercase tracking-[0.3em] text-white/50 transition-colors hover:border-[#c9a84c]/50 hover:text-[#c9a84c]"
              >
                View Details
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Mini footer inside container -->
    <div class="bg-[#0d0d0d] px-6 py-12 md:px-12">
      <div class="grid grid-cols-1 items-start gap-10 md:grid-cols-3">

        <!-- Quick Links -->
        <div class="space-y-4">
          <h4 class="text-[9px] font-semibold uppercase tracking-[0.3em] text-[#c9a84c]">
            Quick Links
          </h4>
          <ul class="space-y-2">
            {quickLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-[10px] uppercase tracking-widest text-white/30 transition-colors hover:text-white"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Contact -->
        <div class="space-y-4">
          <h4 class="text-[9px] font-semibold uppercase tracking-[0.3em] text-[#c9a84c]">
            Contact
          </h4>
          <ul class="space-y-2">
            <li class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0 text-[#c9a84c]/60" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
              </svg>
              <a href={`tel:${siteConfig.contact.phone.replace(/\s/g, "")}`}
                class="text-[10px] uppercase tracking-widest text-white/30 transition-colors hover:text-white">
                {siteConfig.contact.phone}
              </a>
            </li>
            <li class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0 text-[#c9a84c]/60" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
              <a href={`mailto:${siteConfig.contact.email}`}
                class="text-[10px] uppercase tracking-widest text-white/30 transition-colors hover:text-white">
                {siteConfig.contact.email}
              </a>
            </li>
          </ul>
        </div>

        <!-- Logo + Socials -->
        <div class="flex flex-col items-center gap-6 md:items-end">
          <a href="#hero" class="flex items-center gap-2">
            <img src="/images/logo.png" alt="Alliance Granite & Quartz" class="h-8 w-auto opacity-80" />
          </a>
          <div class="flex gap-5">
            <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook"
              class="text-white/30 transition-colors hover:text-[#c9a84c]">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M22 12c0-5.522-4.477-10-10-10S2 6.478 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
              </svg>
            </a>
            <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram"
              class="text-white/30 transition-colors hover:text-[#c9a84c]">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
          </div>
        </div>

      </div>
    </div>

  </div>
</main>

<script>
  const el = document.getElementById("floating-overview");
  if (el) {
    const startOffset = el.offsetTop; // position where it sits initially

    window.addEventListener("scroll", () => {
      const scrollY = window.scrollY;

      // Only apply while the element is in the "overlap" zone above its natural position
      if (scrollY <= startOffset + el.offsetHeight) {
        // Move up at 0.4× scroll speed — soft parallax
        const translateY = -scrollY * 0.4;
        el.style.transform = `translateY(${translateY}px)`;
      }
    }, { passive: true });
  }
</script>
