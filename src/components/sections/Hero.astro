---
const heroImage = "/images/bg.jpg";
---

<section
  id="hero"
  class="relative flex h-[85vh] w-full flex-col items-center justify-center overflow-hidden text-white"
  style={`background-image: url('${heroImage}'); background-size: cover; background-position: center;`}
>
  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-black/55"></div>

  <!-- Centered content -->
  <div class="relative z-10 flex flex-col items-center px-6 pb-24 pt-20 text-center">
    <div class="hero-anim flex items-center gap-2" style="animation-delay: 0.2s;">
      <span class="text-xl text-[#c9a84c]">★★★★★</span>
      <span class="text-sm text-stone-300">Rated 5 stars by customers</span>
    </div>

    <h1 class="hero-anim mt-6 max-w-3xl font-serif text-5xl font-light leading-tight md:text-7xl" style="animation-delay: 0.45s;">
      Elegant Granite<br />
      <em class="not-italic text-[#c9a84c]/90">and Quartz Solutions</em>
    </h1>

    <p class="hero-anim mt-6 max-w-xl text-base text-stone-300 md:text-lg" style="animation-delay: 0.65s;">
      Discover premium countertops and surfaces for your kitchen with our exquisite selection.
    </p>

    <a
      href="#services"
      class="hero-anim mt-8 inline-block border border-[#c9a84c] px-10 py-3 text-sm font-medium uppercase tracking-[0.15em] text-white transition hover:bg-[#c9a84c] hover:text-stone-900"
      style="animation-delay: 0.85s;"
    >
      Explore our Collection
    </a>
  </div>
</section>
