---
import { siteConfig } from "../data/site";
---

<footer class="bg-[#080808] px-6 py-20 text-white">
  <div class="mx-auto max-w-7xl">
    <!-- Top: main grid -->
    <div class="grid gap-12 border-b border-white/5 pb-14 md:grid-cols-4">

      <!-- Brand -->
      <div class="md:col-span-2">
        <img src="/images/logo.png" alt="Alliance Granite & Quartz" class="mb-4 h-12 w-auto opacity-80" />
        <p class="max-w-xs text-sm leading-relaxed text-white/40">
          Premium granite, quartz and marble surfaces for kitchens, bathrooms and living spaces.
        </p>
        <div class="mt-6 flex gap-4">
          <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook"
            class="text-white/30 transition hover:text-[#c9a84c]">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M22 12c0-5.522-4.477-10-10-10S2 6.478 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
            </svg>
          </a>
          <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram"
            class="text-white/30 transition hover:text-[#c9a84c]">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <p class="mb-5 text-[10px] uppercase tracking-[0.3em] text-white/30">Navigation</p>
        <ul class="space-y-3 text-sm text-white/50">
          {["Home", "About", "Collections", "Services", "Reviews", "Contact"].map((link) => (
            <li>
              <a href={`#${link.toLowerCase()}`} class="transition hover:text-[#c9a84c]">{link}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="mb-5 text-[10px] uppercase tracking-[0.3em] text-white/30">Contact</p>
        <ul class="space-y-3 text-sm text-white/50">
          <li>
            <a href={`tel:${siteConfig.contact.phone.replace(/\s/g, "")}`} class="transition hover:text-[#c9a84c]">
              {siteConfig.contact.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${siteConfig.contact.email}`} class="transition hover:text-[#c9a84c]">
              {siteConfig.contact.email}
            </a>
          </li>
          <li class="leading-relaxed">{siteConfig.contact.address}</li>
          <li>{siteConfig.contact.hours}</li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col items-center justify-between gap-4 pt-8 text-[11px] uppercase tracking-widest text-white/20 md:flex-row">
      <p>&copy; {new Date().getFullYear()} Alliance Granite &amp; Quartz. All rights reserved.</p>
      <p>Palm, PA &mdash; Serving the Greater Philadelphia Area</p>
    </div>

  </div>
</footer>
