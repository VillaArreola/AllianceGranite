---
import { siteConfig } from "../data/site";
---

<footer class="bg-stone-950 px-6 py-14 text-stone-300">
  <div class="mx-auto grid max-w-5xl gap-12 md:grid-cols-3">
    <!-- Col 1: Brand -->
    <div>
      <h3 class="text-xl font-bold text-white">Elegance</h3>
      <p class="mt-3 text-sm leading-relaxed text-stone-400">
        Premium marble, cuartz and granite for your spaces.
      </p>
      <div class="mt-6 flex items-center gap-5">
        <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook"
          class="text-stone-400 transition hover:text-white">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M22 12c0-5.522-4.477-10-10-10S2 6.478 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
          </svg>
        </a>
        <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram"
          class="text-stone-400 transition hover:text-white">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Col 2: Quality / Contact -->
    <div>
      <h4 class="text-xs font-bold uppercase tracking-widest text-stone-400">Quality</h4>
      <ul class="mt-4 space-y-2 text-sm">
        <li>
          <a href={`tel:${siteConfig.contact.phone.replace(/\s/g, "")}`}
            class="transition hover:text-white">{siteConfig.contact.phone}</a>
        </li>
        <li>
          <a href={`mailto:${siteConfig.contact.email}`}
            class="transition hover:text-white">{siteConfig.contact.email}</a>
        </li>
      </ul>
    </div>

    <!-- Col 3: Newsletter -->
    <div>
      <h4 class="text-xs font-bold uppercase tracking-widest text-stone-400">Service</h4>
      <form class="mt-4 space-y-3">
        <label class="block text-sm text-stone-300" for="footer-email">
          Enter your email address
        </label>
        <input
          id="footer-email"
          name="email"
          type="email"
          placeholder="example@domain.com"
          class="w-full rounded border border-stone-700 bg-stone-900 px-4 py-2 text-sm text-white placeholder-stone-500 outline-none focus:border-[#c9a84c] focus:ring-1 focus:ring-[#c9a84c]"
        />
        <button
          type="submit"
          class="w-full rounded bg-[#8d7a49] px-4 py-2 text-sm font-semibold text-white transition hover:bg-[#6f6038]"
        >
          subscribe for more information
        </button>
      </form>
    </div>
  </div>
</footer>
