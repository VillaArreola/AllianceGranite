---
interface Props {
  title: string;
  url: string;
  description?: string;
}

const { title, url, description = "" } = Astro.props;

// Encode URL and text for sharing
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
const encodedDescription = encodeURIComponent(description);
const shareText = encodeURIComponent(`${title}\n${description ? description + "\n" : ""}${url}`);

// Share URLs
const shareLinks = {
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
  instagram: `https://www.instagram.com/`,
  whatsapp: `https://wa.me/?text=${shareText}`
};
---

<div class="mt-12 border-t border-white/10 pt-12">
  <div class="flex flex-col items-start gap-6">
    <div data-reveal>
      <p class="mb-2 text-[10px] uppercase tracking-[0.35em] text-[#c9a84c]/80">Share Project</p>
      <h3 class="font-serif text-2xl md:text-3xl">Connect & Inspire</h3>
    </div>

    <div class="flex gap-4">
      <!-- Facebook Share Button -->
      <a
        href={shareLinks.facebook}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Share on Facebook"
        data-reveal
        data-reveal-delay="1"
        class="group flex h-14 w-14 items-center justify-center rounded border border-white/20 bg-[#101010] text-white transition-all duration-300 hover:border-[#c9a84c] hover:bg-[#c9a84c]/10 hover:shadow-lg hover:shadow-[#c9a84c]/20"
        title="Share on Facebook"
      >
        <svg class="h-6 w-6 transition-transform group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
        </svg>
      </a>

      <!-- Instagram Share Button -->
      <a
        href={shareLinks.instagram}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Follow on Instagram"
        data-reveal
        data-reveal-delay="2"
        class="group flex h-14 w-14 items-center justify-center rounded border border-white/20 bg-[#101010] text-white transition-all duration-300 hover:border-[#c9a84c] hover:bg-[#c9a84c]/10 hover:shadow-lg hover:shadow-[#c9a84c]/20"
        title="Follow on Instagram"
      >
        <svg class="h-6 w-6 transition-transform group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5" fill="none" stroke="currentColor" stroke-width="2" />
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37Z" fill="none" stroke="currentColor" stroke-width="2" />
          <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" />
        </svg>
      </a>

      <!-- WhatsApp Share Button -->
      <a
        href={shareLinks.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Share on WhatsApp"
        data-reveal
        data-reveal-delay="3"
        class="group flex h-14 w-14 items-center justify-center rounded border border-white/20 bg-[#101010] text-white transition-all duration-300 hover:border-[#c9a84c] hover:bg-[#c9a84c]/10 hover:shadow-lg hover:shadow-[#c9a84c]/20"
        title="Share on WhatsApp"
      >
        <svg class="h-6 w-6 transition-transform group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347M12 0C5.373 0 0 5.373 0 12c0 2.106.547 4.08 1.494 5.779L0 24l6.514-1.423A12 12 0 1 0 12 0z" />
        </svg>
      </a>
    </div>

    <p class="text-xs text-white/45">
      Share this project with your network and get inspired by premium craftsmanship.
    </p>
  </div>
</div>
