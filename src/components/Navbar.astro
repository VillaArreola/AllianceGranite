---
import { siteConfig } from "../data/site";

const pathname = Astro.url.pathname;

const navLinks = [
  { href: "/",         label: "Home",        match: pathname === "/" },
  { href: "/collections", label: "Collections", match: pathname === "/collections" },
  { href: "/services", label: "Services",    match: pathname === "/services" },
  { href: "/portfolio", label: "Portfolio",  match: pathname.startsWith("/portfolio") },
  { href: "/contact",  label: "Contact",     match: pathname === "/contact" },
  { href: "/about",    label: "About",       match: pathname === "/about" },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 w-full">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">

    <!-- Logo -->
    <a href="/" class="relative z-50 flex items-center gap-3">
      <img src="/images/logo.png" alt="Alliance Granite & Quartz" class="h-14 w-auto md:h-16" />
    </a>

    <!-- Desktop nav links -->
    <ul class="hidden items-center gap-8 md:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class={`text-[12px] font-medium uppercase tracking-[0.15em] transition-colors hover:text-[#c9a84c] ${
              link.match ? "text-[#c9a84c]" : "text-stone-300"
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop social icons -->
    <div class="hidden items-center gap-4 md:flex">
      <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook"
        class="text-white/70 transition hover:text-[#c9a84c]">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M22 12c0-5.522-4.477-10-10-10S2 6.478 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
        </svg>
      </a>
      <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram"
        class="text-white/70 transition hover:text-[#c9a84c]">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" class="relative z-50 flex h-10 w-10 flex-col items-center justify-center gap-0 md:hidden" aria-label="Toggle menu" aria-expanded="false">
      <span class="ham-line ham-1"></span>
      <span class="ham-line ham-2"></span>
      <span class="ham-line ham-3"></span>
    </button>

  </nav>
</header>

<!-- Mobile full-screen overlay -->
<div id="mobile-menu" aria-hidden="true">
  <div class="absolute left-1/2 top-28 h-px w-12 -translate-x-1/2 bg-[#c9a84c]/20"></div>

  <nav class="flex flex-col items-center gap-7">
    {navLinks.map((link) => (
      <a href={link.href} class="mobile-nav-link font-serif text-[2.6rem] font-light italic text-white/60 transition-colors hover:text-[#c9a84c]">
        {link.label}
      </a>
    ))}
  </nav>

  <div class="absolute bottom-14 flex gap-8">
    <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook"
      class="text-white/55 transition hover:text-[#c9a84c]">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
        <path d="M22 12c0-5.522-4.477-10-10-10S2 6.478 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
      </svg>
    </a>
    <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram"
      class="text-white/55 transition hover:text-[#c9a84c]">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
      </svg>
    </a>
  </div>
</div>

<style>
  /* ── Navbar scroll state ─────────────────────────────── */
  #site-header {
    background-color: rgba(8, 8, 8, 0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 2px 24px rgba(0, 0, 0, 0.55);
    transition: background-color 0.4s ease, box-shadow 0.4s ease;
  }

  #site-header.scrolled {
    background-color: rgba(8, 8, 8, 0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 2px 24px rgba(0, 0, 0, 0.55);
  }

  /* ── Hamburger lines ─────────────────────────────────── */
  .ham-line {
    display: block;
    height: 1px;
    background: white;
    transition: transform 0.32s ease, opacity 0.32s ease, width 0.32s ease;
  }

  .ham-1 { width: 24px; }
  .ham-2 { width: 24px; margin-top: 6px; }
  .ham-3 { width: 16px; margin-top: 6px; }

  #menu-toggle.is-open .ham-1 { transform: translateY(7px) rotate(45deg); }
  #menu-toggle.is-open .ham-2 { opacity: 0; }
  #menu-toggle.is-open .ham-3 { transform: translateY(-7px) rotate(-45deg); width: 24px; }

  /* ── Mobile overlay ──────────────────────────────────── */
  #mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 40;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: #080808;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  #mobile-menu.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Mobile nav links ────────────────────────────────── */
  .mobile-nav-link {
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity 0.45s ease,
      transform 0.45s ease,
      color 0.2s ease;
  }

  #mobile-menu.is-open .mobile-nav-link { opacity: 1; transform: translateY(0); }
  #mobile-menu.is-open .mobile-nav-link:nth-child(1) { transition-delay: 0.08s; }
  #mobile-menu.is-open .mobile-nav-link:nth-child(2) { transition-delay: 0.16s; }
  #mobile-menu.is-open .mobile-nav-link:nth-child(3) { transition-delay: 0.24s; }
  #mobile-menu.is-open .mobile-nav-link:nth-child(4) { transition-delay: 0.32s; }
  #mobile-menu.is-open .mobile-nav-link:nth-child(5) { transition-delay: 0.40s; }
  #mobile-menu.is-open .mobile-nav-link:nth-child(6) { transition-delay: 0.48s; }
</style>

<script>
  const header  = document.getElementById("site-header") as HTMLElement;
  const toggle  = document.getElementById("menu-toggle") as HTMLButtonElement;
  const menu    = document.getElementById("mobile-menu") as HTMLElement;
  const links   = menu.querySelectorAll(".mobile-nav-link");

  function openMenu() {
    menu.classList.add("is-open");
    toggle.classList.add("is-open");
    toggle.setAttribute("aria-expanded", "true");
    menu.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    menu.classList.remove("is-open");
    toggle.classList.remove("is-open");
    toggle.setAttribute("aria-expanded", "false");
    menu.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  toggle.addEventListener("click", () => {
    toggle.classList.contains("is-open") ? closeMenu() : openMenu();
  });

  links.forEach((link) => link.addEventListener("click", closeMenu));

  // Scroll detection
  window.addEventListener("scroll", () => {
    header.classList.toggle("scrolled", window.scrollY > 70);
  }, { passive: true });
</script>
